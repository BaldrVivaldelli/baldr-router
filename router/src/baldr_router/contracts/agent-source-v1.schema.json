{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baldr.dev/contracts/agent-source-v1.schema.json",
  "title": "Baldr external agent source v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "version",
    "source",
    "candidates",
    "warnings"
  ],
  "properties": {
    "contract": {
      "const": "baldr-agent-source"
    },
    "version": {
      "const": 1
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "candidates": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "warnings": {
      "type": "array",
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "label"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$"
        },
        "kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,31}$"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "source_kind"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$"
        },
        "source_kind": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,31}$"
        },
        "locator": {
          "type": "string",
          "maxLength": 2048
        },
        "scope": {
          "type": "string",
          "maxLength": 64
        },
        "native_id": {
          "type": "string",
          "maxLength": 160
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manifest",
        "provenance",
        "state"
      ],
      "properties": {
        "manifest": {
          "$ref": "agent-registry-v1.schema.json#/$defs/agent"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "state": {
          "enum": [
            "available",
            "shadowed",
            "unavailable"
          ]
        },
        "reason": {
          "type": "string",
          "maxLength": 160
        },
        "label": {
          "type": "string",
          "maxLength": 160
        },
        "description": {
          "type": "string",
          "maxLength": 512
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "available"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "not": {
              "required": [
                "reason"
              ]
            }
          },
          "else": {
            "required": [
              "reason"
            ],
            "properties": {
              "reason": {
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        }
      }
    }
  }
}
