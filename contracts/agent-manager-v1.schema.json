{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baldr.dev/contracts/agent-manager-v1.schema.json",
  "title": "Baldr Agent Manager contracts v1",
  "oneOf": [
    { "$ref": "#/$defs/resolution" },
    { "$ref": "#/$defs/catalog" },
    { "$ref": "#/$defs/health" },
    { "$ref": "#/$defs/admin" },
    { "$ref": "#/$defs/audit" },
    { "$ref": "#/$defs/metrics" },
    { "$ref": "#/$defs/probe" },
    { "$ref": "#/$defs/publication" },
    { "$ref": "#/$defs/policy" }
  ],
  "$defs": {
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "manifest"],
      "properties": {
        "contract": { "const": "baldr-agent-resolution" },
        "version": { "const": 1 },
        "manifest": { "$ref": "agent-registry-v1.schema.json#/$defs/agent" }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "agents"],
      "properties": {
        "contract": { "const": "baldr-agent-catalog" },
        "version": { "const": 1 },
        "agents": {
          "type": "array",
          "maxItems": 1000,
          "items": { "$ref": "agent-registry-v1.schema.json#/$defs/agent" }
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "status"],
      "properties": {
        "contract": { "const": "baldr-agent-manager-health" },
        "version": { "const": 1 },
        "status": { "enum": ["ok", "degraded"] },
        "service_version": { "type": "string", "maxLength": 128 },
        "registry": { "type": "string", "maxLength": 128 },
        "schema_version": { "type": "integer", "minimum": 0 },
        "policy_mode": { "type": "string", "maxLength": 64 },
        "principal": { "type": "string", "maxLength": 96 },
        "uptime_seconds": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "enabled": { "type": "integer", "minimum": 0 },
        "revoked": { "type": "integer", "minimum": 0 }
      }
    },
    "admin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "ok", "reference"],
      "properties": {
        "contract": { "const": "baldr-agent-manager-admin" },
        "version": { "const": 1 },
        "ok": { "const": true },
        "reference": { "type": "string", "maxLength": 512 },
        "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "created": { "type": "boolean" },
        "enabled": { "type": "boolean" },
        "revoked": { "type": "boolean" },
        "actor": { "type": "string", "maxLength": 96 },
        "tenant": { "type": "string", "maxLength": 96 },
        "request_id": { "type": "string", "maxLength": 128 },
        "audit_sequence": { "type": "integer", "minimum": 1 }
      }
    },
    "auditEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sequence",
        "occurred_at",
        "request_id",
        "principal_id",
        "tenant",
        "action",
        "reference",
        "outcome",
        "status_code",
        "detail_code"
      ],
      "properties": {
        "sequence": { "type": "integer", "minimum": 1 },
        "occurred_at": { "type": "string", "maxLength": 64 },
        "request_id": { "type": "string", "maxLength": 128 },
        "principal_id": { "type": "string", "maxLength": 96 },
        "tenant": { "type": "string", "maxLength": 96 },
        "action": { "type": "string", "maxLength": 64 },
        "reference": { "type": "string", "maxLength": 512 },
        "outcome": { "enum": ["allowed", "denied", "failed"] },
        "status_code": { "type": "integer", "minimum": 100, "maximum": 599 },
        "detail_code": { "type": "string", "maxLength": 96 }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "events", "next_after"],
      "properties": {
        "contract": { "const": "baldr-agent-manager-audit" },
        "version": { "const": 1 },
        "events": {
          "type": "array",
          "maxItems": 200,
          "items": { "$ref": "#/$defs/auditEvent" }
        },
        "next_after": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contract",
        "version",
        "registry",
        "schema_version",
        "uptime_seconds",
        "total",
        "enabled",
        "revoked",
        "requests",
        "denied",
        "failed",
        "last_audit_sequence"
      ],
      "properties": {
        "contract": { "const": "baldr-agent-manager-metrics" },
        "version": { "const": 1 },
        "registry": { "type": "string", "maxLength": 128 },
        "schema_version": { "type": "integer", "minimum": 0 },
        "uptime_seconds": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "enabled": { "type": "integer", "minimum": 0 },
        "revoked": { "type": "integer", "minimum": 0 },
        "requests": { "type": "integer", "minimum": 0 },
        "denied": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "last_audit_sequence": { "type": "integer", "minimum": 0 }
      }
    },
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "probe", "status"],
      "properties": {
        "contract": { "const": "baldr-agent-manager-probe" },
        "version": { "const": 1 },
        "probe": { "enum": ["live", "ready"] },
        "status": { "enum": ["ok", "degraded"] }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "manifest"],
      "properties": {
        "contract": { "const": "baldr-agent-publication" },
        "version": { "const": 1 },
        "manifest": { "$ref": "agent-registry-v1.schema.json#/$defs/agent" }
      }
    },
    "principal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "credential_env", "roles", "tenants", "owners"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$" },
        "credential_env": { "type": "string", "pattern": "^[A-Z_][A-Z0-9_]{0,127}$" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "maxItems": 5,
          "uniqueItems": true,
          "items": { "enum": ["reader", "publisher", "operator", "auditor", "admin"] }
        },
        "tenants": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?:\\*|[a-z0-9][a-z0-9._-]{0,95})$" }
        },
        "owners": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^(?:\\*|[a-z0-9][a-z0-9 ._/-]{0,159})$" }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract", "version", "registry", "principals"],
      "properties": {
        "contract": { "const": "baldr-agent-manager-policy" },
        "version": { "const": 1 },
        "registry": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{0,95}$" },
        "principals": {
          "type": "array",
          "minItems": 1,
          "maxItems": 128,
          "items": { "$ref": "#/$defs/principal" }
        }
      }
    }
  }
}
